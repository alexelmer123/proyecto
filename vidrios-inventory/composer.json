{
    "name": "vitralia/realtime",
    "description": "Servidor WebSocket en tiempo real para Vitralia — broadcast de cambios de stock entre usuarios conectados.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "cboden/ratchet": "^0.4.4",
        "react/http": "^1.9"
    },
    "autoload": {
        "psr-4": {
            "Vitralia\\Realtime\\": "app/realtime/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
